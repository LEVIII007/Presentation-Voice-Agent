# Copy to .env and fill in.
DEEPGRAM_API_KEY=

# LLM + vision narration: Azure OpenAI (one gpt-5-mini deployment does both)
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini

# Voice TTS provider: "cartesia" or "azure"
TTS_PROVIDER=cartesia
CARTESIA_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE=en-US-Ava:DragonHDLatestNeural

# Optional overrides
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121
PORT=7860

# Storage & limits (defaults are fine for local/dev)
# DATA_DIR=data
# DATABASE_URL=                      # empty -> sqlite under DATA_DIR; set postgres+asyncpg://... in prod
# MAX_SESSIONS=20                    # concurrent voice-session cap
# MAX_UPLOAD_MB=40
# MAX_SLIDES=60
# NARRATION_CONCURRENCY=2            # parallel vision calls during ingestion (tune to Azure TPM)
# VOICE_ALWAYS_SHOW_SLIDE_IMAGE=false # rollback: keep the current slide image in every live turn

# PPTX upload needs LibreOffice for PPTX->PDF. Auto-detected on PATH / macOS;
# set explicitly if it lives elsewhere. Without it, PDF uploads still work.
# SOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice

# Only needed when hosting behind a public domain (e.g. https://demo.example.com)
# PUBLIC_URL=
